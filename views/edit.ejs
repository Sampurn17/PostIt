<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <a class="bg-red-500 rounded-md px-3 py-2 text-sm" href="/logout">LOGOUT</a>

            <h5 class ="mb-5">edit your post</h5>
            <form action="/update/<%= post._id %>" method="post">
                <textarea placeholder="What's on your mind" class= "mt-3 block w-1/3 p-3 outline-none resize-none transparent-bg  border-2 border-zinc-800 rounded-md " name="content"><%= post.content %></textarea>
                <input class = "block px-3 py-2 w-35 rounded-md text-black mt-2 bg-yellow-500" type="submit" value="Edit post">
            </form>
        </div>
    
</body>
</html>