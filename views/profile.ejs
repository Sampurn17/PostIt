<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <a class="bg-red-500 rounded-md px-3 py-2 text-sm" href="/logout">LOGOUT</a>
        <h3 class="text-3xl mt-3"><span class="font-light ">Hello, <%= user.name %></h3>
            <h5 class ="mb-5">You can create a post</h5>
            <form action="/post" method="post">
                <textarea placeholder="What's on your mind" class= "mt-3 block w-1/3 p-3 outline-none resize-none transparent-bg  border-2 border-zinc-800 rounded-md " name="content"></textarea>
                <input class = "block px-3 py-2 w-35 rounded-md mt-2 bg-blue-500" type="submit" value="Create post">
            </form>
            <div class="posts mt-20">
                <h3 class="text-zinc-500">Your Posts.</h3>
                
                    <% user.posts.reverse().forEach(function(post){ %>
                <div type="postcontainer" class="rounded-md post w-1/3 p-4 border-2 border-zinc-700 bg-zinc-800 mb-2">
                    <h4 class="text-blue-500 mb-2"><%= user.username %></h4>
                    <h5 class="tracking-tighter text-sm"><%= post.content %>
                    </h5>
                    <small class="mt-2 inline block"><%= post.likes.length %>Likes</small>
                    <div class="btns flex gap-4 mt-5">
                        <a class = "text-blue-400" href="/like/<%= post._id%>">
                            <%= post.likes.indexOf(user._id)===-1? "Like":"UNLIKE" %>
                        </a>
                        <a class = "text-zinc-600" href="/edit/<%= post._id %>">Edit</a>
                    </div>

            </div>
            <% }) %>

    </div>
    
</body>
</html>